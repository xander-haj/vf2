{
  "name": "voxel-frontier",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "content:validate": "node tools/content-compiler/validate-content.mjs",
    "content:generate": "node tools/content-compiler/generate-content.mjs",
    "test:content": "node --test tools/content-compiler/content-compiler.test.mjs",
    "editor": "vite --mode editor --open /editor.html",
    "build": "npm run content:generate && tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/three": "0.185.1",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  }
}
